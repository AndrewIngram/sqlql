{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@tupl/schema": ["./packages/schema/src/index.ts"],
      "@tupl/provider-drizzle": ["./packages/provider-drizzle/src/index.ts"],
      "@tupl/provider-ioredis": ["./packages/provider-ioredis/src/index.ts"],
      "@tupl/provider-objection": ["./packages/provider-objection/src/index.ts"],
      "@tupl/provider-kysely": ["./packages/provider-kysely/src/index.ts"],
      "@tupl/foundation": ["./packages/foundation/src/index.ts"],
      "@tupl/test-support": ["./packages/test-support/src/index.ts"],
      "@tupl/test-support/*": ["./packages/test-support/src/*"],
      "@tupl/provider-kit": ["./packages/provider-kit/src/index.ts"],
      "@tupl/provider-kit/relational-sql": ["./packages/provider-kit/src/relational-sql.ts"],
      "@tupl/provider-kit/shapes": ["./packages/provider-kit/src/provider/shapes/index.ts"],
      "@tupl/provider-kit/testing": ["./packages/provider-kit/src/testing.ts"],
      "@tupl/schema-model": ["./packages/schema-model/src/index.ts"],
      "@tupl/schema-model/constraints": ["./packages/schema-model/src/constraints.ts"],
      "@tupl/schema-model/ddl": ["./packages/schema-model/src/ddl.ts"],
      "@tupl/schema-model/definition": ["./packages/schema-model/src/definition.ts"],
      "@tupl/schema-model/dsl": ["./packages/schema-model/src/dsl.ts"],
      "@tupl/schema-model/enums": ["./packages/schema-model/src/enums.ts"],
      "@tupl/schema-model/mapping": ["./packages/schema-model/src/mapping/index.ts"],
      "@tupl/schema-model/normalized": ["./packages/schema-model/src/normalized.ts"],
      "@tupl/schema-model/normalization": ["./packages/schema-model/src/normalization.ts"],
      "@tupl/schema-model/planning": ["./packages/schema-model/src/planning.ts"],
      "@tupl/schema-model/table-planning": ["./packages/schema-model/src/table-planning.ts"],
      "@tupl/planner": ["./packages/planner/src/index.ts"],
      "@tupl/runtime": ["./packages/runtime/src/index.ts"],
      "@tupl/runtime/executor": ["./packages/runtime/src/runtime/executor.ts"],
      "@tupl/runtime/session": ["./packages/runtime/src/runtime/session/index.ts"],
      "@tupl/example-shared": ["./examples/_shared/src/index.ts"]
    }
  },
  "include": ["vite.config.ts", "scripts/**/*.ts"]
}
