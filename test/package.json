{
  "name": "@tupl/workspace-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vp test run --root .. --config ../vite.config.ts",
    "test:coverage": "vp test run --root .. --config ../vite.config.ts --coverage",
    "test:ci": "vp test run --root .. --config ../vite.config.ts --coverage --reporter=default --reporter=blob --outputFile.blob=../.vitest-reports/test-ci.json --cacheDir=../node_modules/.vite-ci/vitest",
    "test:watch": "vp test --root .. --config ../vite.config.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@typescript/native-preview": "latest",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.2",
    "vite-plus": "latest"
  }
}
